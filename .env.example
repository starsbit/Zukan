DATABASE_URL=postgresql+asyncpg://zukan:zukan@localhost:5432/zukan

SECRET_KEY=change-me-run-openssl-rand-hex-32

STORAGE_DIR=storage
MODEL_CACHE_DIR=model_cache

TAGGER_MODEL_REPO=SmilingWolf/wd-vit-tagger-v3
TAGGER_THRESHOLD_GENERAL=0.35
TAGGER_THRESHOLD_CHARACTER=0.85

# Tagging concurrency — increase for faster queue drain (each worker uses one DB connection)
TAGGING_WORKER_COUNT=2
# ONNX and OCR thread pool sizes — InferenceSession.run() is thread-safe
TAGGER_EXECUTOR_WORKERS=2
OCR_EXECUTOR_WORKERS=2

ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

HOST=0.0.0.0
PORT=8000

ANILIST_CLIENT_ID=1234
ANILIST_CLIENT_SECRET=change-me
ANILIST_OAUTH_REDIRECT_URI=http://localhost:4200/auth/anilist/callback
LOG_LEVEL=WARNING

ZUKAN_TOKEN=change-me-api-key-or-bearer-token
SYNC_INTERVAL_SECONDS=900
DEFAULT_VISIBILITY=private
DEFAULT_TAGS=[]

TWITTER_AUTH_TOKEN=change-me
TWITTER_CT0=change-me
TWITTER_USER_ID=123456789
